{
  "name": "albrings",
  "version": "1.0.1",
  "description": "Albring's - Gestão para Eletricistas",
  "main": "main.js",
  "scripts": {
    "start": "start.bat",
    "launch": "ELECTRON_RUN_AS_NODE=0 ./node_modules/electron/dist/electron . --disable-gpu",
    "rebuild": "electron-rebuild",
    "dist": "electron-builder"
  },
  "author": "Albring's",
  "license": "MIT",
  "build": {
    "appId": "com.albrings.app",
    "productName": "Albring's",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "**/*",
      "!dist/*",
      "!start.bat",
      "!test_electron.js"
    ],
    "cscLink": null
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "googleapis": "^171.4.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "electron-rebuild": "^3.2.9"
  }
}
